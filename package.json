    "jest-mock-extended": "^3.0.5"
  },
  "scripts": {
    "start": "expo start",
    "start:phone": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-expo-go-phone.ps1",
    "qr:phone": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-expo-go-qr.ps1",
    "start:clean": "expo start -c",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "build:offline-waveform": "npx tsx scripts/build-offline-waveform.ts",
    "export:tokyo-fare-waveform": "npx tsx scripts/export-tokyo-fare-waveform.ts",
    "export:ueno-fare-waveform": "npx tsx scripts/export-ueno-fare-waveform.ts",
    "publish:fare-waveform-tokyo-json": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-fare-waveform-tokyo-json.ps1",
    "publish:fare-waveform-ueno-json": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-fare-waveform-ueno-json.ps1",
    "fetch:business-chains": "node scripts/fetch-business-chain-seed.mjs",
    "fetch:business-chains:full": "node scripts/fetch-business-chain-seed.mjs --full",
    "import:shareholder-meetings": "node scripts/import-shareholder-meetings.mjs",
    "fetch:shareholder-meetings": "python scripts/fetch-shareholder-meetings-edinetdb.py",
    "fetch:shareholder-meetings:dry": "python scripts/fetch-shareholder-meetings-edinetdb.py --dry-run",
    "fetch:shareholder-meetings-edinet": "python scripts/fetch-shareholder-meetings-edinet.py",
    "fetch:shareholder-meetings-edinet:dry": "python scripts/fetch-shareholder-meetings-edinet.py --dry-run",
    "setup:shareholder-meetings-auto-fetch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-shareholder-meetings-scheduler.ps1",
    "uninstall:shareholder-meetings-auto-fetch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-shareholder-meetings-scheduler.ps1",
    "run:shareholder-meetings-auto-fetch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/scheduled-fetch-shareholder-meetings.ps1",
    "publish:shareholder-meetings-json": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-shareholder-meetings-json.ps1",
    "import:medical-meetings": "node scripts/import-medical-meetings.mjs",
    "fetch:medical-meetings": "python scripts/fetch-medical-meetings.py",
    "fetch:medical-meetings:dry": "python scripts/fetch-medical-meetings.py --dry-run",
    "setup:medical-meetings-auto-fetch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-medical-meetings-scheduler.ps1",
    "uninstall:medical-meetings-auto-fetch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-medical-meetings-scheduler.ps1",
    "run:medical-meetings-auto-fetch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/scheduled-fetch-medical-meetings.ps1",
    "publish:medical-meetings-json": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-medical-meetings-json.ps1",
    "import:cruise-terminals": "node scripts/import-cruise-terminals.mjs",
    "fetch:cruise-terminals": "python scripts/fetch-cruise-terminals.py",
    "fetch:cruise-ship-master": "python scripts/fetch-cruise-ship-master.py",
    "fetch:cruise-ship-master:dry": "python scripts/fetch-cruise-ship-master.py --dry-run",
    "fetch:cruise-terminals:dry": "python scripts/fetch-cruise-terminals.py --dry-run",
    "fetch:cruise-terminals:seed": "python scripts/fetch-cruise-terminals.py --seed-only",
    "setup:cruise-terminals-auto-fetch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-cruise-terminals-scheduler.ps1",
    "run:cruise-terminals-auto-fetch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/scheduled-fetch-cruise-terminals.ps1",
    "publish:cruise-terminals-json": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-cruise-terminals-json.ps1",
    "validate:powershell": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validate-powershell-scripts.ps1",
    "validate:fetch-scripts": "python -m unittest discover -s scripts -p \"test_*.py\" -v"
  },
  "private": true
}
